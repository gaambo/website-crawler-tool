{
  "name": "website-crawler-tool",
  "version": "1.1.0",
  "description": "A Node.js CLI tool to crawl a website and run accessibility checks.",
  "main": "dist/index.js",
  "bin": {
    "website-crawler": "./dist/index.js"
  },
  "scripts": {
    "start": "npm run build && node dist/index.js",
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gaambo/website-crawler-tool.git"
  },
  "keywords": [
    "crawler",
    "accessibility",
    "a11y",
    "seo",
    "checker"
  ],
  "author": "gaambo",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.9.0",
    "cheerio": "^1.1.0",
    "commander": "^14.0.0",
    "csv-writer": "^1.6.0",
    "p-limit": "^3.1.0",
    "robots-parser": "^2.1.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.1",
    "@types/xml2js": "^0.4.14",
    "prettier": "^2.8.8",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
